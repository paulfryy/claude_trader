# Alpaca API credentials
# Get these from https://app.alpaca.markets/
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Set to "paper" for paper trading, "live" for real money
ALPACA_TRADING_MODE=paper

# Anthropic API key
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_api_key_here

# Claude model to use for analysis
CLAUDE_MODEL=claude-sonnet-4-6-20250514

# Risk parameters
MAX_POSITION_PCT=0.15          # Max 15% of portfolio in one position
MAX_TOTAL_EXPOSURE_PCT=0.90    # Max 90% of portfolio deployed
MAX_OPTIONS_EXPOSURE_PCT=0.30  # Max 30% of portfolio in options
MAX_DRAWDOWN_PCT=0.15          # Halt trading if portfolio drops 15%
STOP_LOSS_DEFAULT_PCT=0.08     # Default stop-loss at 8%

# Logging
LOG_LEVEL=INFO
